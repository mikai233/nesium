import { ScrollView, ComboBox, Button, Slider, CheckBox, TabWidget } from "std-widgets.slint";

export component DebugRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> mono-font-family: "Noto Sans SC";

    height: 24px;
    background: transparent;

    HorizontalLayout {
        spacing: 8px;

        Text {
            width: 84px;
            text: root.label;
            color: #5a554b;
            font-size: 13px;
            vertical-alignment: center;
        }

        Text {
            horizontal-stretch: 1;
            text: root.value;
            color: #171513;
            font-size: 13px;
            font-family: root.mono-font-family;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component MenuTrigger inherits Rectangle {
    in property <string> title;
    in property <bool> open;
    callback activated();

    width: 64px;
    height: 32px;
    background: touch.pressed ? #dde7fb : (touch.has-hover || root.open ? #edf3ff : transparent);

    animate background {
        duration: 100ms;
    }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.title;
        color: #1f2328;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.activated();
        }
    }
}

export component MenuPopupItem inherits Rectangle {
    in property <string> title;
    in property <bool> enabled: true;
    callback activated();

    min-width: item_layout.min-width;
    min-height: max(30px, item_layout.min-height);
    background: touch.pressed ? #dbe7ff : (touch.has-hover && root.enabled ? #eef3ff : transparent);

    animate background {
        duration: 90ms;
    }

    item_layout := HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;

        label := Text {
            text: root.title;
            color: root.enabled ? #1f2328 : #99a1ad;
            font-size: 13px;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        clicked => {
            root.activated();
        }
    }
}

export component MenuPopupSeparator inherits Rectangle {
    height: 1px;
    background: #e6ebf2;
}

export component MenuPopupPanel inherits Rectangle {
    in property <bool> open;
    in property <length> panel-x;
    in property <length> panel-y;

    x: root.panel-x;
    y: root.open ? root.panel-y : root.panel-y - 4px;
    visible: root.open || self.opacity > 0.01;
    opacity: root.open ? 1 : 0;
    width: popup_layout.min-width;
    height: popup_layout.min-height;
    background: #ffffff;
    border-width: 1px;
    border-color: #d9e1ec;
    border-radius: 8px;
    drop-shadow-color: #22000000;
    drop-shadow-offset-y: 4px;
    drop-shadow-blur: 14px;
    clip: true;

    popup_layout := VerticalLayout {
        padding: 6px;
        spacing: 2px;

        @children
    }

    animate opacity {
        duration: 120ms;
    }

    animate y {
        duration: 120ms;
    }
}

export component PlaceholderContent inherits Rectangle {
    in property <string> heading;
    in property <string> body;

    width: 100%;
    height: 100%;
    background: #efeae0;

    ScrollView {
        width: parent.width;
        height: parent.height;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        VerticalLayout {
            width: parent.visible-width;
            padding-left: 18px;
            padding-right: 18px;
            padding-top: 16px;
            padding-bottom: 16px;
            spacing: 10px;

            Text {
                text: root.heading;
                color: #1f1c18;
                font-size: 16px;
                font-weight: 700;
            }

            Text {
                text: root.body;
                color: #615a50;
                font-size: 13px;
                wrap: word-wrap;
            }

            Rectangle {
                vertical-stretch: 1;
                background: transparent;
            }
        }
    }
}
